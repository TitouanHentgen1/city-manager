void log_action(const char *dir_name, const char *user, const char *role) {
    char log_path[512];
    sprintf(log_path, "%s/logged_district", dir_name);
    
    FILE *f = fopen(log_path, "a");
    if (f) {
        time_t now = time(NULL);
        fprintf(f, "[%ld] User: %s | Role: %s | Action: Filtered records\n", 
                now, user, role);
        fclose(f);
    }
}
