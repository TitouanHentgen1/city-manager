#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <fcntl.h>
#include <unistd.h>

#define NAME_LEN 64
#define CAT_LEN 32
#define DESC_LEN 256

typedef struct {
    int id;
    char inspector[NAME_LEN];
    double lat;
    double lon;
    char category[CAT_LEN];
    int severity;
    time_t timestamp;
    char description[DESC_LEN];
} Report;

typedef struct {
    char field[32];
    char op[8];
    char value[64];
} Condition;
